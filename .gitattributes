# Normalize line endings to LF in the repository,
# check out as CRLF on Windows.
* text=auto eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no line-ending conversion.
*.png binary
*.ico binary
*.icns binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.exe binary
