{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Email Downloader",
  "version": "0.1.0",
  "identifier": "com.emaildownloader.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Email Downloader",
        "width": 1200,
        "height": 800,
        "minWidth": 940,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUxODFBREIxRkEwRDFERTQKUldUa0hRMzZzYTJCNFg3b1ZEYWZLZkRGcWRSV0VkS2lEdi8zZW5iWmI0aURzYk5aSDZpYS9TSnUK",
      "endpoints": [
        "https://github.com/janayuv/email-downloader/releases/latest/download/latest.json"
      ]
    }
  }
}
